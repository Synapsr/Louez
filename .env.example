# ===========================================
# Louez - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# All variables without defaults are REQUIRED
# See README.md for detailed documentation

# -----------------------------------------
# Database (Required)
# -----------------------------------------
# MySQL connection string
DATABASE_URL="mysql://user:password@localhost:3306/louez"

# -----------------------------------------
# Authentication (Required)
# -----------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Auth URL - Must match your dashboard URL (where users log in)
# Examples: http://localhost:3000 (dev) | https://app.yourdomain.com (prod)
AUTH_URL="http://localhost:3000"

# Trust Host - Set to true when behind a reverse proxy (Docker, Cloudflare, etc.)
AUTH_TRUST_HOST="true"

# Google OAuth (Required for Google sign-in)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# -----------------------------------------
# Email / SMTP (Required)
# -----------------------------------------
# Any SMTP provider works: Gmail, SendGrid, Mailgun, AWS SES, Resend, etc.
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="resend"
SMTP_PASSWORD=""
SMTP_FROM="Louez <noreply@yourdomain.com>"

# -----------------------------------------
# Application URLs (Required)
# -----------------------------------------
# Base URL and domain for your installation
# Examples: http://localhost:3000 / localhost:3000 (dev)
#           https://app.yourdomain.com / yourdomain.com (prod)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DOMAIN="localhost:3000"

# Subdomain used for the admin dashboard (default: "app")
# Dashboard will be accessible at: {DASHBOARD_SUBDOMAIN}.{APP_DOMAIN}
NEXT_PUBLIC_DASHBOARD_SUBDOMAIN="app"

# -----------------------------------------
# Storage / S3 (Required)
# -----------------------------------------
# For image uploads. S3-compatible providers:
# AWS S3, Scaleway Object Storage, MinIO, Cloudflare R2, DigitalOcean Spaces
S3_ENDPOINT="https://s3.fr-par.scw.cloud"
S3_REGION="fr-par"
S3_BUCKET="louez-uploads"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL="https://louez-uploads.s3.fr-par.scw.cloud"

# -----------------------------------------
# Stripe (Required)
# -----------------------------------------
# For online payments with Stripe Connect
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Stripe Price IDs (EUR) - Create in Stripe Dashboard
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
STRIPE_PRICE_ULTRA_MONTHLY=""
STRIPE_PRICE_ULTRA_YEARLY=""

# Stripe Price IDs (USD) - Create in Stripe Dashboard
STRIPE_PRICE_PRO_MONTHLY_USD=""
STRIPE_PRICE_PRO_YEARLY_USD=""
STRIPE_PRICE_ULTRA_MONTHLY_USD=""
STRIPE_PRICE_ULTRA_YEARLY_USD=""

# -----------------------------------------
# SMS (Required)
# -----------------------------------------
# For sending SMS notifications to customers
# Provider options: smspartner, twilio, vonage
SMS_PROVIDER="smspartner"
SMS_DEFAULT_SENDER="Louez"

# SMS Partner (https://www.smspartner.fr)
# Get your API key from: https://my.smspartner.fr/api
SMS_PARTNER_API_KEY=""

# -----------------------------------------
# Google Places (Required)
# -----------------------------------------
# For address autocomplete and search
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACES_CACHE_TTL_HOURS="120"

# -----------------------------------------
# Platform Admin (Required)
# -----------------------------------------
# Comma-separated list of emails with platform-wide admin access.
# These users can access ALL stores in the store switcher for support/debugging.
# Leave empty to disable this feature.
PLATFORM_ADMIN_EMAILS=""

# -----------------------------------------
# Pay-as-you-go default pricing (Optional)
# -----------------------------------------
# JSON describing the per-rental pricing snapshotted onto every NEW store at account
# creation — a way to run ephemeral launch offers by deploying a config change instead
# of editing code. It only affects accounts created AFTER the deploy; existing stores
# keep the pricing snapshotted when they were created. Validated at boot (a malformed
# value fails the deploy). Leave empty to use the hardcoded platform default ladder.
# Flat rate (e.g. 0.25€ per rental, for every rental):
#   PAYG_DEFAULT_PRICING='{"flatRateCents":25,"currency":"eur"}'
# Graduated ladder (monthly reset; e.g. 0.25€ up to 50, 0.50€ up to 80, 1€ beyond):
#   PAYG_DEFAULT_PRICING='{"tiers":[{"upToCount":50,"priceCents":25},{"upToCount":80,"priceCents":50},{"upToCount":null,"priceCents":100}],"currency":"eur"}'
PAYG_DEFAULT_PRICING=""

# Free reservations gifted to a NEW store at account creation (welcome allowance). While
# credits remain, the per-rental commission is waived. Snapshotted per store at creation
# and editable per store in admin; changing this only affects future accounts. Default 15.
PAYG_FREE_RESERVATIONS="15"

# -----------------------------------------
# Referral program (Optional)
# -----------------------------------------
# Free reservations granted to the referrer when a referral qualifies. A subscribed
# referrer receives the equivalent value as invoice credit. Default 30.
REFERRAL_REFERRER_REWARD="30"

# Free reservations granted to the referred store at sign-up. Default 30.
REFERRAL_REFERRED_REWARD="30"

# Minimum online payment, in cents, required to unlock the referrer reward. Default 2000.
REFERRAL_MIN_QUALIFYING_CENTS="2000"

# Maximum rewards a single referrer can earn per month. 0 means unlimited. Default 0.
REFERRAL_MONTHLY_CAP="0"

# Refund/dispute clawback window after reward grant, in days. Default 30.
REFERRAL_CLAWBACK_DAYS="30"

# -----------------------------------------
# Discord Notifications (Required)
# -----------------------------------------
# Discord webhook URL for platform-wide admin notifications.
# When set, key platform events (sign-ups, reservations, payments, etc.)
# are sent as single-line messages to this Discord channel in real-time.
# Create a webhook: Discord Server Settings > Integrations > Webhooks > New Webhook
DISCORD_ADMIN_WEBHOOK_URL=""

# -----------------------------------------
# Cron Jobs (Required)
# -----------------------------------------
# Secret for authenticating cron job requests
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# -----------------------------------------
# AI (Optional)
# -----------------------------------------
# Powers the dashboard AI assistant and the storefront AI advisor.
# Both features stay hidden when unset.
# AI_PROVIDER: anthropic | openai | google
AI_PROVIDER=""
AI_API_KEY=""
# Optional model override (defaults per provider)
AI_MODEL=""
# Optional cheaper model for the public storefront advisor
# (falls back to AI_MODEL, then the provider default)
AI_ADVISOR_MODEL=""
# Optional per-store daily message cap for the storefront advisor (default 500)
AI_ADVISOR_DAILY_STORE_LIMIT=""

# -----------------------------------------
# AI Phone receptionist (Optional — inbound voice channel)
# -----------------------------------------
# Answers inbound phone calls with the SAME AI agent as the storefront advisor,
# in a language configured per store. Requires the AI vars above (AI_PROVIDER /
# AI_API_KEY). Stays completely hidden until AI_PHONE_ENABLED is "true" AND a
# voice provider is configured.
# Master switch — set to "true" to enable the feature.
AI_PHONE_ENABLED=""
# Telephony provider serving inbound calls. Only "twilio" is implemented.
VOICE_PROVIDER=""
# Twilio credentials — validate inbound webhook signatures (X-Twilio-Signature).
# Point your Twilio number's Voice webhook (A CALL COMES IN) to:
#   https://<app-domain>/api/voice/incoming   (HTTP POST)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Optional cheaper/faster model for the phone agent
# (falls back to AI_ADVISOR_MODEL, then AI_MODEL, then the provider default)
AI_PHONE_MODEL=""
# Hard cap on a single call's duration in seconds (default 600 = 10 min)
AI_PHONE_MAX_CALL_SECONDS=""
# --- Streaming transport (Twilio ConversationRelay + ElevenLabs) ---
# Phone transport. "gather" (default/unset) = turn-based Twilio <Gather> (robust,
# serverless-only). "relay" = streaming ConversationRelay (Deepgram STT +
# ElevenLabs TTS + barge-in) via the self-hosted apps/voice-relay worker. Needs
# VOICE_RELAY_WS_URL + VOICE_RELAY_SIGNING_SECRET, else it stays on <Gather>.
AI_PHONE_TRANSPORT=""
# Public wss:// URL of the ConversationRelay worker (apps/voice-relay).
VOICE_RELAY_WS_URL=""
# HMAC secret shared with the worker (authenticates both directions). Generate a
# strong random value and set the SAME value on the worker.
VOICE_RELAY_SIGNING_SECRET=""
# ConversationRelay TTS/STT providers (default "ElevenLabs" / "Deepgram").
AI_PHONE_TTS_PROVIDER=""
AI_PHONE_STT_PROVIDER=""
# ElevenLabs voice id per app locale, JSON, e.g.
# {"fr":"<voiceId>","en":"<voiceId>","de":"<voiceId>", ...}. A per-store voice
# (set in the dashboard) overrides it.
AI_PHONE_VOICES=""
# Fallback voice id when a locale is absent from AI_PHONE_VOICES.
AI_PHONE_DEFAULT_VOICE=""

# -----------------------------------------
# PostHog Analytics (Required)
# -----------------------------------------
# Product analytics, feature flags, and session replay
# Get your keys from: https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
# Optional override; Docker builds generate one automatically when omitted
NEXT_PUBLIC_APP_VERSION=""

# -----------------------------------------
# Umami Analytics (Required)
# -----------------------------------------
# Privacy-friendly analytics for your platform
# Full URL to your Umami tracking script
NEXT_PUBLIC_UMAMI_SCRIPT_URL=""
# Website ID from your Umami dashboard (Settings > Websites > Edit)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""

# -----------------------------------------
# Gleap (Required)
# -----------------------------------------
# For in-app feedback and bug reporting in the dashboard
NEXT_PUBLIC_GLEAP_API_KEY=""

# -----------------------------------------
# OpenReplay (Optional)
# -----------------------------------------
# Session replay. Disabled unless the ingest point and a surface project key are set.
# Use separate projects for dashboard and storefront.
NEXT_PUBLIC_OPENREPLAY_PROJECT_KEY=""
NEXT_PUBLIC_OPENREPLAY_STOREFRONT_PROJECT_KEY=""
NEXT_PUBLIC_OPENREPLAY_INGEST_POINT=""

# -----------------------------------------
# fromHello (Optional)
# -----------------------------------------
# Growth marketing & engagement platform (event tracking, journeys, segments)
# API URL and tracking key from your fromHello dashboard (Tracking > Setup)
NEXT_PUBLIC_FROMHELLO_API_URL=""
NEXT_PUBLIC_FROMHELLO_KEY=""
# Set to e.g. ".louez.io" when marketing and the app live on different
# subdomains so the fh_aid cookie follows visitors across the signup
# boundary. Leave empty for single-domain deploys.
NEXT_PUBLIC_FROMHELLO_COOKIE_DOMAIN=""
# Server-side event tracking (same URL and key, used for action events)
FROMHELLO_API_URL=""
FROMHELLO_API_KEY=""

# -----------------------------------------
# Development Mode (Optional)
# -----------------------------------------
# Set to a store slug to preview that store's storefront locally
# When set, localhost will show the storefront instead of the dashboard
# Dashboard routes (/dashboard, /login, etc.) remain accessible
PREVIEW_STORE_SLUG=""

# Auto-run migrations on server start (dev only)
AUTO_DB_SETUP="false"

# Skip env validation during build (use with caution)
# SKIP_ENV_VALIDATION="true"
