# Voice Relay worker environment.
# These belong to the worker only — they are NOT part of the app's env.

# TCP port the worker listens on (HTTP health check + WebSocket upgrades).
# Optional; defaults to 8080.
PORT=8080

# Absolute https URL of the app's Server-Sent-Events turn endpoint.
# Required — the worker fails fast at startup if this is missing.
TURN_ENDPOINT_URL=https://app.example.com/api/voice/turn

# HMAC-SHA256 secret shared with the app. Used to (1) validate the inbound
# WebSocket handshake token and (2) sign each turn request to the app.
# Required — the worker fails fast at startup if this is missing.
# Must be identical to the app's VOICE_RELAY_SIGNING_SECRET.
VOICE_RELAY_SIGNING_SECRET=replace-with-a-long-random-secret
