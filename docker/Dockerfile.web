# syntax=docker/dockerfile:1

# =============================================================================
# Louez Web App - Production Dockerfile (Turborepo Monorepo)
# =============================================================================
# Optimized multi-stage build for Next.js standalone output
# Image size: ~150MB | Startup: <5s | Non-root user
#
# Features:
# - Dedicated migrator target (run separately from app)
# - Health checks for container orchestrators
# - Non-root user for security
# - Turborepo monorepo support
#
# Build:  docker build -f docker/Dockerfile.web -t louez-web .
# Run:    docker run -p 3000:3000 --env-file .env louez-web
# Migrate: docker build -f docker/Dockerfile.web --target migrator -t louez-migrator .
# EasyPanel (no build target): use docker/Dockerfile.web for app and
# docker/Dockerfile.web.migrator for migrations.
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1: Dependencies
# Install all npm dependencies in isolated stage for better caching
# -----------------------------------------------------------------------------
FROM node:20-alpine AS deps

# libc6-compat is needed for some npm packages on Alpine
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy workspace configuration files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json .npmrc ./

# Copy all package.json files for workspace packages
COPY packages/api/package.json ./packages/api/
COPY packages/auth/package.json ./packages/auth/
COPY packages/config/package.json ./packages/config/
COPY packages/types/package.json ./packages/types/
COPY packages/utils/package.json ./packages/utils/
COPY packages/validations/package.json ./packages/validations/
COPY packages/db/package.json ./packages/db/
COPY packages/ui/package.json ./packages/ui/
COPY packages/email/package.json ./packages/email/
COPY packages/pdf/package.json ./packages/pdf/
COPY packages/mcp/package.json ./packages/mcp/
COPY apps/web/package.json ./apps/web/
COPY apps/voice-relay/package.json ./apps/voice-relay/

# Install dependencies using pnpm
RUN corepack enable pnpm && \
    pnpm install --frozen-lockfile

# -----------------------------------------------------------------------------
# Stage 2: Builder
# Build the Next.js application with standalone output using Turborepo
# -----------------------------------------------------------------------------
FROM node:20-alpine AS builder

WORKDIR /app

# Build-time env vars forwarded by EasyPanel (`--build-arg ...`)
ARG SKIP_ENV_VALIDATION=true
ARG DATABASE_URL

# NEXT_PUBLIC_* vars are inlined by Next.js at build time — they MUST be
# available during `next build` or they will be baked in as `undefined`.
ARG NEXT_PUBLIC_APP_URL
ARG NEXT_PUBLIC_APP_DOMAIN
ARG NEXT_PUBLIC_DASHBOARD_SUBDOMAIN
ARG NEXT_PUBLIC_APP_VERSION
ARG NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
ARG NEXT_PUBLIC_POSTHOG_KEY
ARG NEXT_PUBLIC_POSTHOG_HOST
ARG NEXT_PUBLIC_UMAMI_SCRIPT_URL
ARG NEXT_PUBLIC_UMAMI_WEBSITE_ID
ARG NEXT_PUBLIC_GLEAP_API_KEY
ARG NEXT_PUBLIC_FROMHELLO_API_URL
ARG NEXT_PUBLIC_FROMHELLO_KEY
ARG NEXT_PUBLIC_FROMHELLO_COOKIE_DOMAIN

# Copy dependencies
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/api/node_modules ./packages/api/node_modules
COPY --from=deps /app/packages/auth/node_modules ./packages/auth/node_modules
# @louez/config is source-only and has no node_modules directory.
COPY --from=deps /app/packages/types/node_modules ./packages/types/node_modules
COPY --from=deps /app/packages/utils/node_modules ./packages/utils/node_modules
COPY --from=deps /app/packages/validations/node_modules ./packages/validations/node_modules
COPY --from=deps /app/packages/db/node_modules ./packages/db/node_modules
COPY --from=deps /app/packages/ui/node_modules ./packages/ui/node_modules
COPY --from=deps /app/packages/email/node_modules ./packages/email/node_modules
COPY --from=deps /app/packages/pdf/node_modules ./packages/pdf/node_modules
COPY --from=deps /app/packages/mcp/node_modules ./packages/mcp/node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules

# Copy source code
COPY . .

# Disable telemetry during build
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production
ENV SKIP_ENV_VALIDATION=${SKIP_ENV_VALIDATION}
ENV DATABASE_URL=${DATABASE_URL}
ENV NEXT_PUBLIC_APP_URL=${NEXT_PUBLIC_APP_URL}
ENV NEXT_PUBLIC_APP_DOMAIN=${NEXT_PUBLIC_APP_DOMAIN}
ENV NEXT_PUBLIC_DASHBOARD_SUBDOMAIN=${NEXT_PUBLIC_DASHBOARD_SUBDOMAIN}
ENV NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=${NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY}
ENV NEXT_PUBLIC_POSTHOG_KEY=${NEXT_PUBLIC_POSTHOG_KEY}
ENV NEXT_PUBLIC_POSTHOG_HOST=${NEXT_PUBLIC_POSTHOG_HOST}
ENV NEXT_PUBLIC_UMAMI_SCRIPT_URL=${NEXT_PUBLIC_UMAMI_SCRIPT_URL}
ENV NEXT_PUBLIC_UMAMI_WEBSITE_ID=${NEXT_PUBLIC_UMAMI_WEBSITE_ID}
ENV NEXT_PUBLIC_GLEAP_API_KEY=${NEXT_PUBLIC_GLEAP_API_KEY}
ENV NEXT_PUBLIC_FROMHELLO_API_URL=${NEXT_PUBLIC_FROMHELLO_API_URL}
ENV NEXT_PUBLIC_FROMHELLO_KEY=${NEXT_PUBLIC_FROMHELLO_KEY}
ENV NEXT_PUBLIC_FROMHELLO_COOKIE_DOMAIN=${NEXT_PUBLIC_FROMHELLO_COOKIE_DOMAIN}

# Build the application using Turborepo. CI supplies the commit SHA; direct
# EasyPanel builds fall back to a unique build identifier without manual input.
RUN corepack enable pnpm && \
    APP_VERSION="${NEXT_PUBLIC_APP_VERSION:-build-$(date -u +%Y%m%d%H%M%S)}" && \
    NEXT_PUBLIC_APP_VERSION="${APP_VERSION}" pnpm turbo run build --filter=@louez/web --env-mode=loose

# -----------------------------------------------------------------------------
# Stage 3: Migrator
# One-off image used to run database migrations
# -----------------------------------------------------------------------------
FROM node:20-alpine AS migrator

WORKDIR /app

ENV NODE_ENV=production

# Copy node_modules needed by migrate.mjs (drizzle-orm, mysql2, and their deps)
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/db/node_modules ./packages/db/node_modules

# Copy migration script and migration files
COPY --from=builder /app/docker/migrate.mjs ./docker/migrate.mjs
COPY --from=builder /app/packages/db/src/migrations ./migrations

CMD ["node", "docker/migrate.mjs"]

# -----------------------------------------------------------------------------
# Stage 4: App (Production)
# Minimal image with only the standalone build output
# -----------------------------------------------------------------------------
FROM node:20-alpine AS app

WORKDIR /app

# Install wget for health checks and create non-root user
RUN apk add --no-cache wget && \
    addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Production environment
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Copy standalone build (includes server.js and minimal node_modules)
# The standalone output preserves the monorepo structure
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

# Copy public assets (static files) - must match monorepo structure
# --chown so the non-root nextjs user can read them regardless of the
# permissions the files had on the build host
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

# Copy SQL migrations so the app can set up an empty database at startup
# (setupDatabase in packages/db runs them programmatically — drizzle-kit is
# a dev tool and is not available in this image)
COPY --from=builder --chown=nextjs:nodejs /app/packages/db/src/migrations ./migrations
ENV MIGRATIONS_FOLDER=/app/migrations

# Entrypoint generates a persistent AUTH_SECRET under /app/data when the
# operator provides none (standalone zero-config path). The directory must
# exist owned by the runtime user so a named volume inherits its ownership.
COPY --chown=nextjs:nodejs docker/entrypoint.sh ./docker/entrypoint.sh
RUN chmod +x ./docker/entrypoint.sh && \
    mkdir -p /app/data && chown nextjs:nodejs /app/data

# Switch to non-root user
USER nextjs

# Expose application port
EXPOSE 3000

# Health check for container orchestrators (EasyPanel, Dokploy, Kubernetes)
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD sh -c "wget --no-verbose --tries=1 --spider http://localhost:\${PORT:-3000}/api/health || exit 1"

# Start standalone Next.js server
ENTRYPOINT ["./docker/entrypoint.sh"]
CMD ["node", "apps/web/server.js"]
